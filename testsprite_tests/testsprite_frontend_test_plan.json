[
  {
    "id": "TC001",
    "title": "Guest can add one menu item to cart and place order to reach QR confirmation",
    "description": "Verifies an unauthenticated guest can add an item to cart, checkout, place an order, and see the QR confirmation page.",
    "category": "Guest Ordering Flow",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Type \"susushi\" into the restaurant slug field"
      },
      {
        "type": "action",
        "description": "Type \"1\" into the table number field"
      },
      {
        "type": "action",
        "description": "Press Enter"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/menu\""
      },
      {
        "type": "action",
        "description": "Click \"Add to cart\" on the first visible menu item"
      },
      {
        "type": "action",
        "description": "Click \"Cart\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/cart\""
      },
      {
        "type": "assertion",
        "description": "Verify the cart items list is visible"
      },
      {
        "type": "action",
        "description": "Click \"Checkout\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/checkout\""
      },
      {
        "type": "action",
        "description": "Click \"Place order\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/qr\""
      },
      {
        "type": "assertion",
        "description": "Verify the QR code confirmation element is visible"
      }
    ]
  },
