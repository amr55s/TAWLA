[
  {
    "id": "TC001",
    "title": "Place an order successfully from menu to QR confirmation",
    "description": "Verifies a guest can add an item to cart, proceed to checkout, place an order, and see the QR confirmation page.",
    "category": "Guest Ordering Flow",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /susushi/menu?table=1"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Menu\" is visible"
      },
      {
        "type": "action",
        "description": "Click \"Add to cart\" on the first visible menu item"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Added\" is visible"
      },
      {
        "type": "action",
        "description": "Click \"Checkout\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/checkout\""
      },
      {
        "type": "action",
        "description": "Click \"Place order\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/susushi/qr\""
      }
    ]
  },
