  {
    "id": "TC007",
    "title": "Admin can sign in with valid credentials and reach the Admin dashboard",
    "description": "Verifies that an admin can log in using email/password and is redirected to the /admin dashboard.",
    "category": "Admin Login and Create Menu Item",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sign in\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on \"Sign in\""
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Admin\" is visible"
      }
    ]
  },
