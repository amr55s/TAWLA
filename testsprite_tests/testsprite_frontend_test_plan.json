  {
    "id": "TC007",
    "title": "Admin can sign in and create a new menu item that appears in the list",
    "description": "Verifies an admin can log in with valid credentials, open Admin Menu, create an item, and see it listed.",
    "category": "Admin Login and Create Menu Item",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign in\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "action",
        "description": "Click the \"Menu\" link or navigation item"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin/menu\""
      },
      {
        "type": "action",
        "description": "Click the \"Add Item\" button"
      },
      {
        "type": "action",
        "description": "Type \"E2E Test Item\" into the item name field"
      },
      {
        "type": "action",
        "description": "Type \"12.50\" into the item price field"
      },
      {
        "type": "action",
        "description": "Select \"Sushi\" from the category dropdown"
      },
      {
        "type": "action",
        "description": "Click the \"Create item\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"E2E Test Item\" is visible"
      }
    ]
  },
